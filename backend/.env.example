# ============================================
# Backend environment — copy to .env and fill in
# NEVER commit the real .env file!
# ============================================

# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/apple_disease

# JWT
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# AI Service
AI_SERVICE_URL=http://localhost:8000
USE_MOCK_AI=true

# AWS
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=apple-disease-uploads
